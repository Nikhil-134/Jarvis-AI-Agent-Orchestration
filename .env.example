# Copy this file to .env and fill in local values.

ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM provider switching
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.25

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Memory system
MEMORY_ENABLED=true
MEMORY_VECTOR_STORE_PATH=./memory_data/vectors
MEMORY_DOCUMENT_STORE_PATH=./memory_data/documents.db
MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_SEARCH_TOP_K=5
MEMORY_IMPORTANCE_THRESHOLD=0.3
MEMORY_DEDUP_THRESHOLD=0.95
MEMORY_CLEANUP_MAX_AGE_DAYS=30
MEMORY_WORKING_MEMORY_SIZE=50
MEMORY_WORKING_MEMORY_TTL_SECONDS=3600
# Cross-session persistent memory: record every turn, restore the session on
# boot, and reflect on exit. Disable to keep memory read-only (pre-cycle-5).
MEMORY_PERSIST_ENABLED=true
MEMORY_SESSION_ID=default
# Auto-promote preferences stated in conversation ("call me Boss", "my
# favourite language is Rust") to structured profile entries — no explicit
# "remember" command needed. Disable to keep only raw-turn recording.
MEMORY_AUTO_LEARN_ENABLED=true

# Internet Knowledge Engine (roadmap #9) — context-only, last-resort retrieval
# from public JSON APIs (DuckDuckGo + Wikipedia). No keys, no scraping, no
# cloud LLM. Reasoning stays local. Set INTERNET_ENABLED=false for fully
# offline / air-gapped operation.
INTERNET_ENABLED=true
INTERNET_TIMEOUT_SECONDS=6
INTERNET_OVERALL_TIMEOUT_SECONDS=8
INTERNET_CACHE_TTL_SECONDS=300
INTERNET_MIN_INTERVAL_SECONDS=1
INTERNET_MAX_RESULTS=5

# Planning & Task Execution subsystem (cycle 8) — decomposes complex, actionable
# goals into a dependency task graph, executes them concurrently (retries /
# timeouts / cancellation), routes each task to a real backend by capability,
# and verifies the final answer. Confidence-based routing supersedes regex for
# actionable goals; regex routing stays as the fallback. Set PLANNING_ENABLED=
# false to route exactly as before (regex only).
PLANNING_ENABLED=true
PLANNING_MAX_PARALLEL=4
PLANNING_TASK_TIMEOUT_SECONDS=30
PLANNING_MAX_RETRIES=1
PLANNING_CONFIDENCE_THRESHOLD=0.55
PLANNING_MIN_GOAL_CONFIDENCE=0.5
# Structured telemetry: one JSON line per planner decision / task execution /
# retry / latency / fallback, written to the local rotating log (no network, ₹0).
# Set false to disable (null sink → zero overhead).
PLANNING_TELEMETRY_ENABLED=true

# Voice (100% local — see requirements-voice.txt for setup)
# Disabled by default; text mode is unaffected when off.
VOICE_ENABLED=false
# piper = local & free (recommended). edge = Microsoft online service (NOT local).
VOICE_TTS_PROVIDER=piper
VOICE_PIPER_MODEL=./voice_models/en_US-lessac-medium.onnx
VOICE_STT_MODEL=base
VOICE_WAKE_WORDS=jarvis,computer
VOICE_RECORD_SECONDS=5.0

# Continuous hands-free loop (used by !converse / VOICE_AUTOSTART)
# transcript = require a wake word to activate; none = always listening
VOICE_WAKE_MODE=transcript
VOICE_FRAME_MS=30
VOICE_TRAILING_SILENCE=0.8
VOICE_MAX_UTTERANCE=15.0
VOICE_INACTIVITY_TIMEOUT=30.0
VOICE_GREETING=Yes?
# Launch straight into the hands-free loop on startup
VOICE_AUTOSTART=false
