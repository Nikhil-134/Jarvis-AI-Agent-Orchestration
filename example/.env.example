# Copy this file to .env and fill in local values.

ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM provider switching
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.25

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Memory system
MEMORY_ENABLED=true
MEMORY_VECTOR_STORE_PATH=./memory_data/vectors
MEMORY_DOCUMENT_STORE_PATH=./memory_data/documents.db
MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_SEARCH_TOP_K=5
MEMORY_IMPORTANCE_THRESHOLD=0.3
MEMORY_DEDUP_THRESHOLD=0.95
MEMORY_CLEANUP_MAX_AGE_DAYS=30
MEMORY_WORKING_MEMORY_SIZE=50
MEMORY_WORKING_MEMORY_TTL_SECONDS=3600
